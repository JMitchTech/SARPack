# SARPack — .env.template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.
#
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"

# -----------------------------------------------------------------------
# Operating mode: local | hybrid | cloud
# -----------------------------------------------------------------------
# local  — SQLite only. Toughbook running without internet.
# hybrid — SQLite primary + PostgreSQL sync. Normal field operations.
# cloud  — PostgreSQL direct. Cloud admin/review access only.
SARPACK_MODE=hybrid

# -----------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------
SARPACK_SECRET_KEY=REPLACE_WITH_GENERATED_KEY_MIN_32_CHARS

# -----------------------------------------------------------------------
# Database — SQLite (always required)
# -----------------------------------------------------------------------
# Leave blank to use default: SARPack/database/sarpack.db
SARPACK_SQLITE_PATH=

# -----------------------------------------------------------------------
# Database — PostgreSQL (required if MODE=hybrid or MODE=cloud)
# -----------------------------------------------------------------------
# Format: postgresql://username:password@host:port/database_name
SARPACK_DATABASE_URL=postgresql://sarpack:REPLACE_PASSWORD@localhost:5432/sarpack

# -----------------------------------------------------------------------
# Sync engine
# -----------------------------------------------------------------------
SARPACK_SYNC_INTERVAL=30     # seconds between sync attempts
SARPACK_SYNC_BATCH=100       # outbox entries per sync cycle
SARPACK_SYNC_RETRIES=5       # max retries before an entry is skipped

# -----------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------
SARPACK_SESSION_HOURS=12     # how long login sessions last

# -----------------------------------------------------------------------
# App ports
# -----------------------------------------------------------------------
PORT_BASECAMP=6000
PORT_TRAILHEAD=6001
PORT_RELAY=6002
PORT_LOGBOOK=6003
PORT_WARDEN=6004

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
SARPACK_LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
