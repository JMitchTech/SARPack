# SARPack 2.0 — Environment Configuration
# Copy this file to .env and fill in all values before running
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Security ──────────────────────────────────────────────────────────────────
SARPACK_SECRET_KEY=your_secret_key_minimum_32_characters_here
SARPACK_JWT_EXPIRY_HOURS=12
SARPACK_MFA_ISSUER=SARPack

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use default (project root/sarpack.db)
SARPACK_DB_PATH=

# ── Server ────────────────────────────────────────────────────────────────────
SARPACK_HOST=0.0.0.0
PORT_PORTAL=8000
PORT_TRAILHEAD=8001
SARPACK_DEBUG=false

# ── Uploads ───────────────────────────────────────────────────────────────────
# Leave blank to use default (project root/uploads/)
SARPACK_UPLOAD_FOLDER=
SARPACK_MAX_UPLOAD_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
SARPACK_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8001